{
	"name": "@aegis-framework/pandora",
	"version": "0.3.0",
	"description": "Aegis Framework Web Components Library",
	"type": "module",
	"main": "./dist/pandora.js",
	"module": "./dist/pandora.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/pandora.js",
			"default": "./dist/pandora.js"
		},
		"./browser": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/pandora.browser.js",
			"default": "./dist/pandora.browser.js"
		}
	},
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://gitlab.com/AegisFramework/Pandora.git"
	},
	"bugs": {
		"url": "https://gitlab.com/AegisFramework/Pandora/issues"
	},
	"homepage": "https://aegisframework.com/",
	"author": "Diana Islas Ocampo <dev@hyuchia.com>",
	"license": "MIT",
	"keywords": [
		"pandora",
		"dom",
		"web",
		"component",
		"shadow",
		"javascript",
		"library"
	],
	"scripts": {
		"build": "yarn clean && yarn lint && yarn check && yarn build:module && yarn build:legacy && yarn build:types",
		"build:module": "bun build ./src/index.ts --target browser --format esm --outdir ./dist --sourcemap=linked --minify && mv ./dist/index.js ./dist/pandora.js && mv ./dist/index.js.map ./dist/pandora.js.map && sed -i 's/index.js.map/pandora.js.map/' ./dist/pandora.js",
		"build:legacy": "bun build ./src/browser.ts --target browser --format esm --outdir ./dist --sourcemap=linked --minify && mv ./dist/browser.js ./dist/pandora.browser.js && mv ./dist/browser.js.map ./dist/pandora.browser.js.map && sed -i 's/browser.js.map/pandora.browser.js.map/' ./dist/pandora.browser.js",
		"build:types": "tsc --emitDeclarationOnly --declarationDir ./dist/types",
		"check": "tsc --noEmit",
		"lint": "eslint ./src/**/*.ts",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"@babel/eslint-parser": "^7.28.5",
		"@eslint/js": "^9.39.1",
		"@typescript-eslint/eslint-plugin": "^8.48.1",
		"@typescript-eslint/parser": "^8.48.1",
		"bun": "^1.3.3",
		"eslint": "^9.39.1",
		"http-server": "^14.1.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md",
		"package.json"
	],
	"browserslist": "> 0.5%, last 2 versions, not dead",
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
	"dependencies": {}
}
